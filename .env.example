# ============================================
# Honeypot Platform Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# Alerting Configuration
# --------------------------------------------
# Telegram Bot (Recommended for mobile alerts)
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# Slack Webhook (Optional)
# Create incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Generic Webhook (Optional)
# For custom integrations (Discord, Microsoft Teams, etc.)
WEBHOOK_URL=https://your-webhook-endpoint.com/alerts

# Alert Threshold - Minimum events before alerting
ALERT_THRESHOLD=5

# --------------------------------------------
# Security Configuration
# --------------------------------------------
# Change these in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=honeypot2024

# Session Secret (generate a random string)
SECRET_KEY=your-secret-key-change-in-production

# --------------------------------------------
# Database Configuration (Optional)
# --------------------------------------------
# For persistent storage
DB_HOST=localhost
DB_PORT=5432
DB_NAME=honeypot
DB_USER=honeypot
DB_PASSWORD=change_me

# --------------------------------------------
# Network Configuration
# --------------------------------------------
# Dashboard port
DASHBOARD_PORT=5000

# Honeypot service ports
HTTP_HONEYPOT_PORT=8080
SSH_HONEYPOT_PORT=2222
FTP_HONEYPOT_PORT=2121
SMB_HONEYPOT_PORT=445
DB_HONEYPOT_PORT=3306

# --------------------------------------------
# Feature Flags
# --------------------------------------------
# Enable/disable features
ENABLE_TELEGRAM_ALERTS=true
ENABLE_SLACK_ALERTS=false
ENABLE_WEBHOOK_ALERTS=false
ENABLE_GEOIP=true
ENABLE_PACKET_CAPTURE=true

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# --------------------------------------------
# IOC Detection
# --------------------------------------------
# Patterns to monitor (comma-separated)
IOC_PATTERNS=sql_injection,command_injection,path_traversal,xss,malicious_commands
